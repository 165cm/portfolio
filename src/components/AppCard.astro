---
import type { App } from '../data/apps';
interface Props { app: App }
const { app } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = `${base}${base.endsWith('/') ? '' : '/'}apps/${app.slug}`;
---
<article class="card">
  <div class="card-head">
    <span class="emoji">{app.emoji}</span>
    <h3>{app.name}</h3>
  </div>
  <p class="tagline">{app.tagline}</p>
  <div class="footer-row">
    {app.links.demo && (
      <a class="tag tag--action demo-link" href={app.links.demo} target="_blank" rel="noopener">公開ページ →</a>
    )}
    <a class="tag tag--action detail-link" href={href}>詳しく見る →</a>
  </div>
</article>
